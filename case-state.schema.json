{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AymanShams/codex-coding-os/blob/main/case-state.schema.json",
  "title": "Codex Coding OS Automation Case-State Store",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "revision", "updated_at", "cases", "bindings", "store_events"],
  "properties": {
    "schema_version": { "const": 2 },
    "revision": { "type": "integer", "minimum": 0 },
    "updated_at": { "type": ["string", "null"] },
    "cases": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/case" }
    },
    "bindings": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/caseId" }
    },
    "store_events": { "type": "object" }
  },
  "$defs": {
    "caseId": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "headMap": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/sha" }
    },
    "snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "sha256", "head"],
      "properties": {
        "contract": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/digest" },
        "head": { "$ref": "#/$defs/sha" }
      }
    },
    "snapshotMap": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/snapshot" }
    },
    "legacyReviewSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "sha256"],
      "properties": {
        "contract": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/digest" }
      }
    },
    "reviewSnapshotMap": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "$ref": "#/$defs/snapshot" },
          { "$ref": "#/$defs/legacyReviewSnapshot" }
        ]
      }
    },
    "branchBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "value"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "value": { "type": "string", "minLength": 1 }
      }
    },
    "caseBindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo_url", "branch", "worktree", "pr", "thread", "universal_bundle"],
      "properties": {
        "repo_url": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "branch": { "type": "array", "items": { "$ref": "#/$defs/branchBinding" }, "uniqueItems": true },
        "worktree": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "pr": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "thread": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "universal_bundle": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_heads",
        "review_snapshots",
        "current_heads",
        "repaired_heads",
        "repaired_snapshots",
        "observed_heads"
      ],
      "properties": {
        "review_heads": { "$ref": "#/$defs/headMap" },
        "review_snapshots": { "$ref": "#/$defs/reviewSnapshotMap" },
        "current_heads": { "$ref": "#/$defs/headMap" },
        "repaired_heads": { "$ref": "#/$defs/headMap" },
        "repaired_snapshots": { "$ref": "#/$defs/snapshotMap" },
        "observed_heads": { "$ref": "#/$defs/headMap" }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "implementation_generations",
        "review_cohorts",
        "combined_repairs",
        "closure_checks",
        "operational_retries"
      ],
      "properties": {
        "implementation_generations": { "type": "integer", "minimum": 0, "maximum": 1 },
        "review_cohorts": { "type": "integer", "minimum": 0, "maximum": 1 },
        "combined_repairs": { "type": "integer", "minimum": 0, "maximum": 1 },
        "closure_checks": { "type": "integer", "minimum": 0, "maximum": 1 },
        "operational_retries": { "type": "integer", "minimum": 0, "maximum": 1 }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "case_id",
        "revision",
        "state",
        "resumable_state",
        "objective",
        "created_at",
        "updated_at",
        "bindings",
        "limits",
        "candidate",
        "findings",
        "repair",
        "closure",
        "control",
        "lock_reason",
        "events"
      ],
      "properties": {
        "schema_version": { "const": 2 },
        "case_id": { "$ref": "#/$defs/caseId" },
        "revision": { "type": "integer", "minimum": 1 },
        "state": {
          "enum": [
            "REGISTERED",
            "IMPLEMENTING",
            "CANDIDATE_FROZEN",
            "REVIEW_COLLECTING",
            "FINDINGS_FROZEN",
            "REPAIR_AUTHORIZED",
            "REPAIR_COMPLETE",
            "CLOSURE_PREFLIGHT",
            "CLOSURE_CHECK",
            "CLOSED_SUCCESS",
            "CASE_LOCKED",
            "CONTROL_FAILURE"
          ]
        },
        "resumable_state": { "type": ["string", "null"] },
        "objective": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "bindings": { "$ref": "#/$defs/caseBindings" },
        "limits": { "$ref": "#/$defs/limits" },
        "candidate": { "$ref": "#/$defs/candidate" },
        "findings": { "type": "object" },
        "repair": { "type": "object" },
        "closure": { "type": "object" },
        "control": { "type": "object" },
        "lock_reason": { "type": ["string", "null"] },
        "events": { "type": "object" }
      }
    }
  }
}
